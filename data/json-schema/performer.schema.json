{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "performer.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name"],
  "properties": {
    "id": { "type": "string", "pattern": "^p[1-9]\\d*$" },
    "name": { "type": "string", "minLength": 1 }
  }
}
