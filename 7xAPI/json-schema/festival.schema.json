{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "festival.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "edition", "location", "description", "start_date", "end_date", "tickets", "links"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "edition": { "type": "integer", "minimum": 1, "maximum": 99 },
    "location": { "type": "string", "minLength": 5, "maxLength": 120 },
    "description": { "type": "string", "minLength": 20, "maxLength": 300 },
    "start_date": { "type": "string", "format": "date" },
    "end_date": { "type": "string", "format": "date" },
    "tickets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "name", "price_czk", "description"],
        "properties": {
          "code": { "type": "string", "enum": ["day", "full", "vip"] },
          "name": { "type": "string", "minLength": 1 },
          "price_czk": { "type": "integer", "minimum": 100, "maximum": 99999 },
          "description": { "type": "string", "minLength": 20, "maxLength": 300 }
        }
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "required": ["homepage", "program", "performers", "practical_info", "xml_source"],
      "properties": {
        "homepage": { "type": "string", "pattern": "^[A-Za-z0-9._/\\-]+\\.html$" },
        "program": { "type": "string", "pattern": "^[A-Za-z0-9._/\\-]+\\.html$" },
        "performers": { "type": "string", "pattern": "^[A-Za-z0-9._/\\-]+\\.html$" },
        "practical_info": { "type": "string", "pattern": "^[A-Za-z0-9._/\\-]+\\.html$" },
        "xml_source": { "type": "string", "pattern": "^[A-Za-z0-9._/\\-]+\\.xml$" }
      }
    }
  }
}
